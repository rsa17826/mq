const fs = require('fs');

// Path to your file
const filePath = './MathQuest/MathQuest.js';

let content = fs.readFileSync(filePath, 'utf8');

// Regex matches: function, followed by parenthesized args, followed by an empty brace (with potential whitespace)
// It captures everything from 'function (' up to ')' and replaces the inside with nothing.
const updatedContent = content.replace(/(function\s*)\([^)]*\)(\s*\{\s*\})/g, '$1()$2');

fs.writeFileSync(filePath, updatedContent, 'utf8');
console.log('Empty functions cleaned successfully!');