for img in t1/map/*.jpg; do
  magick "$img" -gravity SouthWest -chop 26x105 "t2/${img%.jpg}.jpg"
done

for file in map/*.jpg; do
  mv "$file" "${file%.jpg}"
done

rm mapSmall
mkdir -p mapSmall
for f in map/*.jpg; do
  magick "$f" -resize 10% "mapSmall/$(basename "$f")"
done

magick t1/map/100,100.jpg -gravity SouthWest -chop 5x0 "map/a.crop.jpg"